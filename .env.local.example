# Supabase（https://supabase.com で取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx...

# Google Calendar API（https://console.cloud.google.com で取得）
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback

# LINE Messaging API（https://developers.line.biz で取得）
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxx
LINE_USER_ID=Uxxxxxxxxxx      # あなたのLINE User ID
LINE_USER_ID_2=Uxxxxxxxxxx    # 夫のLINE User ID

# 子供の名前
KID1_NAME=長女の名前
KID2_NAME=次女の名前

# Cronジョブの認証キー（ランダムな文字列を設定）
CRON_SECRET=my-secret-key-here
